#!/usr/bin/env bash
# twinbox - unified task-facing CLI entry point

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Activate Python environment if available
if [[ -d "$PROJECT_ROOT/python/.venv" ]]; then
    source "$PROJECT_ROOT/python/.venv/bin/activate"
fi

# Add Python source to PYTHONPATH
export PYTHONPATH="$PROJECT_ROOT/python/src:${PYTHONPATH:-}"

# Run task CLI
exec python3 -m twinbox_core.task_cli "$@"
