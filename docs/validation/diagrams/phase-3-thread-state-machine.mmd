stateDiagram-v2
    [*] --> 新邮件到达

    state "新邮件到达" as NEW
    state "意图分类" as CLASSIFY

    NEW --> CLASSIFY : envelope 解析

    state CLASSIFY {
        [*] --> 资源申请
        [*] --> 版本发布
        [*] --> 运维报告
        [*] --> 合规通知
        [*] --> 周报
        [*] --> 其他
    }

    state "资源申请状态机" as LF1_SM {
        [*] --> LF1_申请发起
        LF1_申请发起 --> LF1_审核中 : 收到受理回复
        LF1_审核中 --> LF1_已批准 : 审批通过
        LF1_审核中 --> LF1_已关闭 : 审批驳回
        LF1_已批准 --> LF1_资源发布 : 收到发布通告
        LF1_资源发布 --> LF1_已关闭 : 部署完成
        LF1_申请发起 --> LF1_申请发起 : 48h无回复→remind
        LF1_审核中 --> LF1_审核中 : 72h无更新→remind
    }

    state "版本发布状态机" as LF2_SM {
        [*] --> LF2_提测
        LF2_提测 --> LF2_联调联试 : 测试通过
        LF2_联调联试 --> LF2_发布审批 : 联调通过
        LF2_发布审批 --> LF2_版本发布 : 审批通过
        LF2_版本发布 --> LF2_部署验收 : 部署完成
        LF2_部署验收 --> [*] : 验收通过
        LF2_版本发布 --> LF2_联调联试 : 报错/回滚
        LF2_联调联试 --> LF2_联调联试 : 阻塞信号→remind
    }

    state "运维报告状态机" as LF3_SM {
        [*] --> LF3_日报
        LF3_日报 --> LF3_月报 : 月末触发
        LF3_月报 --> LF3_问题跟进 : 含问题项
        LF3_月报 --> LF3_归档 : 无问题
        LF3_问题跟进 --> LF3_归档 : 问题关闭
        LF3_日报 --> LF3_日报 : 每日周期→summarize
    }

    state "合规通知状态机" as LF4_SM {
        [*] --> LF4_通知接收
        LF4_通知接收 --> LF4_待办提取 : 含截止日期
        LF4_通知接收 --> LF4_升级处理 : 含违规/紧急
        LF4_待办提取 --> LF4_确认回复 : 需回复
        LF4_待办提取 --> LF4_归档 : 无需回复
        LF4_确认回复 --> LF4_归档 : 回复已发
        LF4_待办提取 --> LF4_待办提取 : 截止前24h→remind
    }

    state "周报状态机" as LF5_SM {
        [*] --> LF5_撰写
        LF5_撰写 --> LF5_已发送 : 发送成功
        LF5_已发送 --> LF5_反馈跟进 : 收到回复
        LF5_已发送 --> LF5_归档 : 无回复
        LF5_反馈跟进 --> LF5_归档 : 补充回复完成
        LF5_已发送 --> LF5_汇总 : 月末/季末
        LF5_汇总 --> LF5_归档 : 汇总完成
        LF5_撰写 --> LF5_撰写 : 周五前未发→remind
    }

    资源申请 --> LF1_SM
    版本发布 --> LF2_SM
    运维报告 --> LF3_SM
    合规通知 --> LF4_SM
    周报 --> LF5_SM
    其他 --> [*]

    LF1_SM --> [*]
    LF2_SM --> [*]
    LF3_SM --> [*]
    LF4_SM --> [*]
    LF5_SM --> [*]
