flowchart TD
    subgraph LF1["LF1 资源申请流"]
        L1S1["申请发起\n(classify+remind)"]
        L1S2["审核中\n(remind)"]
        L1S3["已批准\n(summarize+remind)"]
        L1S4["资源发布\n(summarize)"]
        L1S5["已关闭\n(classify)"]
        L1S1 --> L1S2 --> L1S3 --> L1S4 --> L1S5
        L1S2 -->|"驳回"| L1S5
    end

    subgraph LF2["LF2 版本发布流"]
        L2S1["提测\n(classify+remind)"]
        L2S2["联调联试\n(summarize+remind)"]
        L2S3["发布审批\n(remind)"]
        L2S4["版本发布\n(summarize+classify)"]
        L2S5["部署验收\n(summarize)"]
        L2S1 --> L2S2 --> L2S3 --> L2S4 --> L2S5
        L2S4 -->|"报错/回滚"| L2S2
    end

    subgraph LF3["LF3 运维服务报告流"]
        L3S1["日报发送\n(summarize+classify)"]
        L3S2["月报汇总\n(summarize+remind)"]
        L3S3["问题跟进\n(remind+draft)"]
        L3S4["优化建议\n(summarize)"]
        L3S5["归档\n(classify)"]
        L3S1 --> L3S2
        L3S2 --> L3S3
        L3S2 --> L3S4
        L3S3 --> L3S5
        L3S4 --> L3S5
    end

    subgraph LF4["LF4 合规与通知流"]
        L4S1["通知接收\n(classify+remind)"]
        L4S2["待办提取\n(summarize+remind)"]
        L4S3["确认回复\n(draft+remind)"]
        L4S4["归档\n(classify)"]
        L4S5["升级处理\n(remind+draft)"]
        L4S1 --> L4S2
        L4S2 --> L4S3 --> L4S4
        L4S2 --> L4S4
        L4S1 -->|"含违规/紧急"| L4S5
    end

    subgraph LF5["LF5 周报汇报流"]
        L5S1["周报撰写\n(draft+summarize)"]
        L5S2["周报发送\n(classify)"]
        L5S3["反馈跟进\n(draft+remind)"]
        L5S4["汇总归档\n(summarize+draft)"]
        L5S5["归档\n(classify)"]
        L5S1 --> L5S2
        L5S2 -->|"收到回复"| L5S3 --> L5S5
        L5S2 -->|"无回复"| L5S5
        L5S2 -->|"月末/季末"| L5S4 --> L5S5
    end

    LF1 -->|"资源批准触发"| LF2
