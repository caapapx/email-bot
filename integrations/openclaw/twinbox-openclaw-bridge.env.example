# User-level environment file consumed by:
#   %h/.config/systemd/user/twinbox-openclaw-bridge.service
# Recommended install path:
#   %h/.config/twinbox/twinbox-openclaw-bridge.env

# Required by twinbox-openclaw-bridge.service
TWINBOX_CODE_ROOT=/absolute/path/to/twinbox
TWINBOX_STATE_ROOT=/absolute/path/to/twinbox-state
# Legacy compatibility alias; may equal TWINBOX_STATE_ROOT during migration.
TWINBOX_CANONICAL_ROOT=/absolute/path/to/twinbox-state

# Optional override if `openclaw` is not on PATH for the service user.
# OPENCLAW_BIN=/home/your-user/.nvm/versions/node/v24.14.0/bin/openclaw
