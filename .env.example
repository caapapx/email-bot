# 账户基础信息
MAIL_ACCOUNT_NAME=work
MAIL_DISPLAY_NAME=工作邮箱
MAIL_ADDRESS=your.name@example.com

# IMAP 配置
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_ENCRYPTION=tls
IMAP_LOGIN=your.name@example.com
IMAP_AUTH_MODE=password
IMAP_PASS=app_password
# IMAP_KEYRING=openclaw-work-imap

# SMTP 配置
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_ENCRYPTION=tls
SMTP_LOGIN=your.name@example.com
SMTP_AUTH_MODE=password
SMTP_PASS=app_password
# SMTP_KEYRING=openclaw-work-smtp

# 运行参数
TIMEZONE=Asia/Shanghai
MAIL_FETCH_LOOKBACK_HOURS=24
MAIL_FOLDER_INBOX=INBOX
MAIL_FOLDER_SENT=Sent
MAIL_FOLDER_DRAFTS=Drafts
MAIL_FOLDER_TRASH=Trash
MAIL_IMPORTANT_SENDERS=boss@example.com,partner@example.com
MAIL_IGNORE_SENDERS=noreply@example.com,notification@example.com
