MAIL_ACCOUNT_NAME=myTwinbox
MAIL_DISPLAY_NAME=myTwinbox
MAIL_ADDRESS=your.name@example.com

IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_ENCRYPTION=tls
IMAP_LOGIN=your.name@example.com
IMAP_PASS=app_password

SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_ENCRYPTION=tls
SMTP_LOGIN=your.name@example.com
SMTP_PASS=app_password

TIMEZONE=Asia/Shanghai
MAIL_FETCH_LOOKBACK_HOURS=24
MAIL_IMPORTANT_SENDERS=boss@example.com,partner@example.com
MAIL_IGNORE_SENDERS=noreply@example.com,notification@example.com

# LLM — Phase 1 Thinking (intent classification). Pick ONE backend:
# — OpenAI-compatible API (POST …/chat/completions, Authorization: Bearer): LLM_API_KEY=...  LLM_API_URL may be base only (e.g. …/v2); Twinbox appends /chat/completions when missing. LLM_MODEL=...
# — Anthropic Messages API (/v1/messages, x-api-key): ANTHROPIC_API_KEY=sk-ant-...  optional ANTHROPIC_MODEL, ANTHROPIC_BASE_URL
ANTHROPIC_API_KEY=sk-ant-...
TWINBOX_LLM_MODEL=claude-sonnet-4-20250514
